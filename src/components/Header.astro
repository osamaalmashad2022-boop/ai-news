---
const currentPath = Astro.url.pathname;

const navLinks = [
  { name: 'الرئيسية', href: '/' },
  { name: 'الأخبار اليومية', href: '/news' },
  { name: 'دليل الأدوات', href: '/tools' },
  { name: 'عن الموقع', href: '/about' },
];
---

<header class="glass-nav border-b border-dark-border/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-neon-blue via-neon-cyan to-neon-purple p-[2px] shadow-lg shadow-neon-cyan/20 group-hover:shadow-neon-cyan/40 transition-all duration-300">
        <div class="w-full h-full bg-dark-surface rounded-[10px] flex items-center justify-center">
          <svg class="w-6 h-6 text-neon-cyan group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
      </div>
      <div class="flex flex-col">
        <span class="text-xl font-bold font-heading gradient-text">نبض الذكاء</span>
        <span class="text-[10px] text-gray-400 tracking-wider">AI NEWS ARABIC</span>
      </div>
    </a>

    <!-- Navigation Menu -->
    <nav class="hidden md:flex items-center gap-1 bg-dark-surface/60 p-1.5 rounded-full border border-dark-border/40">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
              isActive
                ? 'bg-neon-blue/20 text-neon-cyan border border-neon-cyan/30 shadow-sm'
                : 'text-gray-300 hover:text-white hover:bg-dark-card/60'
            }`}
          >
            {link.name}
          </a>
        );
      })}
    </nav>

    <!-- Search & Actions -->
    <div class="flex items-center gap-3">
      <a
        href="/search"
        class="p-2.5 rounded-xl bg-dark-card/80 text-gray-300 hover:text-neon-cyan border border-dark-border/60 hover:border-neon-cyan/40 transition-all duration-200"
        title="البحث السريع"
        aria-label="Search"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>

      <a
        href="#newsletter"
        class="hidden sm:flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-neon-cyan to-neon-blue text-black font-semibold text-sm hover:opacity-95 shadow-md shadow-neon-cyan/20 transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span>اشترك بالنشرة</span>
      </a>
    </div>
  </div>
</header>
