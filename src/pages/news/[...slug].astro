---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'news'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, summary, category, tags, sourceName, sourceUrl, publishedAt, toolsMentioned, image } = entry.data;

const formattedDate = new Intl.DateTimeFormat('ar-EG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
}).format(new Date(publishedAt));

// Related News in same category
const allNews = await getCollection('news');
const relatedNews = allNews
  .filter((item) => item.slug !== entry.slug && item.data.category === category)
  .slice(0, 3);
---

<BaseLayout title={`${title} - نبض الذكاء`} description={summary} image={image} article={true}>
  <article class="max-w-4xl mx-auto space-y-8 py-4">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-xs text-gray-400">
      <a href="/" class="hover:text-neon-cyan transition-colors">الرئيسية</a>
      <span>/</span>
      <a href="/news" class="hover:text-neon-cyan transition-colors">الأخبار</a>
      <span>/</span>
      <a href={`/category/${encodeURIComponent(category)}`} class="text-neon-cyan font-medium">{category}</a>
    </nav>

    <!-- Article Header -->
    <div class="space-y-4">
      <div class="flex flex-wrap items-center gap-3 text-xs">
        <a
          href={`/category/${encodeURIComponent(category)}`}
          class="px-3 py-1 rounded-full bg-neon-cyan/10 text-neon-cyan border border-neon-cyan/30 font-semibold"
        >
          {category}
        </a>
        <span class="text-gray-400">{formattedDate}</span>
        <span class="text-gray-500">•</span>
        <span class="text-gray-400">المصدر الأصلي: <strong class="text-gray-200">{sourceName}</strong></span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold font-heading text-white leading-tight">
        {title}
      </h1>
    </div>

    <!-- Summary Callout Box -->
    <div class="glass-card p-6 border-r-4 border-r-neon-cyan bg-neon-cyan/5 space-y-2">
      <h3 class="text-xs font-bold text-neon-cyan uppercase tracking-wider">ملخص الخبر:</h3>
      <p class="text-gray-200 text-base sm:text-lg leading-relaxed">
        {summary}
      </p>
    </div>

    <!-- Image if available -->
    {image && (
      <div class="rounded-2xl overflow-hidden border border-dark-border/60 max-h-96">
        <img src={image} alt={title} class="w-full h-full object-cover" />
      </div>
    )}

    <!-- Markdown Content Body -->
    <div class="prose prose-invert max-w-none prose-lg text-gray-200 leading-relaxed space-y-6 pt-4 border-t border-dark-border/40">
      <Content />
    </div>

    <!-- External Source Action Box -->
    <div class="glass-card p-6 flex flex-col sm:flex-row items-center justify-between gap-4 border border-dark-border">
      <div class="space-y-1 text-center sm:text-right">
        <h4 class="text-white font-bold text-sm">تأكيد المصداقية وإسناد المصدر</h4>
        <p class="text-xs text-gray-400">تم تلخيص هذا الخبر تلقائياً وتوثيقه بناءً على مقال المصدر الأصلي.</p>
      </div>

      <a
        href={sourceUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="px-5 py-2.5 rounded-xl bg-neon-blue/20 text-neon-cyan border border-neon-blue/40 text-xs font-bold hover:bg-neon-blue/30 transition-all flex items-center gap-2 flex-shrink-0"
      >
        <span>قراءة المقال في {sourceName}</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <!-- Tags & Mentioned Tools -->
    <div class="space-y-4 pt-4 border-t border-dark-border/40">
      {toolsMentioned && toolsMentioned.length > 0 && (
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold text-gray-400">الأدوات المذكورة:</span>
          {toolsMentioned.map((t) => (
            <span class="text-xs px-2.5 py-1 rounded-lg bg-dark-card text-neon-purple border border-neon-purple/30 font-medium">
              {t}
            </span>
          ))}
        </div>
      )}

      {tags && tags.length > 0 && (
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold text-gray-400">الوسوم:</span>
          {tags.map((tag) => (
            <a
              href={`/tag/${encodeURIComponent(tag)}`}
              class="text-xs px-2.5 py-1 rounded-lg bg-dark-surface text-gray-300 hover:text-white border border-dark-border/60 transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Related Articles -->
    {relatedNews.length > 0 && (
      <div class="space-y-4 pt-10 border-t border-dark-border/60">
        <h3 class="text-xl font-bold font-heading text-white">أخبار ذات صلة</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedNews.map((item) => (
            <a href={`/news/${item.slug}`} class="glass-card p-4 space-y-2 group block">
              <span class="text-[10px] text-neon-cyan">{item.data.category}</span>
              <h4 class="text-sm font-bold text-white group-hover:text-neon-cyan transition-colors line-clamp-2">
                {item.data.title}
              </h4>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
